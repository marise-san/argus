# Configuração do Argus — copie este arquivo para ".env" e preencha.

# Provedor da camada de IA generativa.
#   template -> sem API, explicações geradas localmente (padrão, funciona offline)
#   openai   -> usa a API da OpenAI (exige OPENAI_API_KEY)
ARGUS_LLM_PROVIDER=template

# Modelo usado quando o provedor for "openai".
ARGUS_LLM_MODELO=gpt-4o-mini

# Chave da API (necessária apenas quando ARGUS_LLM_PROVIDER=openai).
OPENAI_API_KEY=
